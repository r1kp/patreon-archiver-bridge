<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light Theme Colors -->
    <Color x:Key="BgColor">#D9F1F5F9</Color>
    <Color x:Key="SidebarBgColor">#B3F8FAFC</Color>
    <Color x:Key="SidebarBorderColor">#E2E8F0</Color>
    <Color x:Key="CardBgColor">#CCFFFFFF</Color>
    <Color x:Key="CardBorderColor">#E2E8F0</Color>
    <Color x:Key="TextColor">#0F172A</Color>
    <Color x:Key="TextDimColor">#64748B</Color>
    <Color x:Key="IconBgColor">#F1F5F9</Color>
    <Color x:Key="IconColor">#475569</Color>
    
    <Color x:Key="GreenColor">#10B981</Color>
    <Color x:Key="GreenBgColor">#ECFDF5</Color>
    <Color x:Key="RedColor">#EF4444</Color>
    <Color x:Key="RedBgColor">#FEF2F2</Color>
    <Color x:Key="YellowColor">#F59E0B</Color>
    <Color x:Key="YellowBgColor">#FFFBEB</Color>
    
    <Color x:Key="AccentColor">#FF5A3C</Color>
    <Color x:Key="AccentHoverColor">#FF7A62</Color>
    <Color x:Key="AccentGlowColor">#33FF5A3C</Color> <!-- 20% opacity of #FF5A3C -->

    <Color x:Key="CardHoverShadowColor">#000000</Color>
    <sys:Double x:Key="CardHoverShadowOpacity" xmlns:sys="clr-namespace:System;assembly=mscorlib">0.05</sys:Double>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="SidebarBgBrush" Color="{StaticResource SidebarBgColor}"/>
    <SolidColorBrush x:Key="SidebarBorderBrush" Color="{StaticResource SidebarBorderColor}"/>
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource TextDimColor}"/>
    <SolidColorBrush x:Key="IconBgBrush" Color="{StaticResource IconBgColor}"/>
    <SolidColorBrush x:Key="IconColorBrush" Color="{StaticResource IconColor}"/>
    
    <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource GreenColor}"/>
    <SolidColorBrush x:Key="GreenBgBrush" Color="{StaticResource GreenBgColor}"/>
    <SolidColorBrush x:Key="RedBrush" Color="{StaticResource RedColor}"/>
    <SolidColorBrush x:Key="RedBgBrush" Color="{StaticResource RedBgColor}"/>
    <SolidColorBrush x:Key="YellowBrush" Color="{StaticResource YellowColor}"/>
    <SolidColorBrush x:Key="YellowBgBrush" Color="{StaticResource YellowBgColor}"/>
    
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentGlowBrush" Color="{StaticResource AccentGlowColor}"/>

    <SolidColorBrush x:Key="ModalOverlayBrush" Color="#66000000"/>
    <SolidColorBrush x:Key="ModalBoxBgBrush" Color="#E0FFFFFF"/>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#CBD5E1"/>
</ResourceDictionary>

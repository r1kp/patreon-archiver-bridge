<Window x:Class="PatreonArchiverBridge.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Patreon Archiver - Bridge Control Center" 
        Height="560" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        >

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="0" GlassFrameThickness="-1"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Custom Update Alert Button Style (Red, Hover scale, Press scale) -->
        <Style x:Key="UpdateAlertButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="BorderBrush" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="1" 
                                CornerRadius="18" 
                                SnapsToDevicePixels="True"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                            </Border.RenderTransform>
                            <ContentPresenter x:Name="contentPresenter" 
                                              HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Hover Effect: Slightly brighter red + subtle scale up -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF5555"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF5555"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1.08" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1.08" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1.0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1.0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <!-- Press Effect: Slightly darker red + scale down -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#DC2626"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#DC2626"/>
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" Background="{DynamicResource BgBrush}" BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="1" CornerRadius="12" RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="WindowScale" ScaleX="1.0" ScaleY="1.0"/>
                <TranslateTransform x:Name="WindowTranslate" Y="0"/>
            </TransformGroup>
        </Border.RenderTransform>
        <Grid x:Name="RootGrid">
            <!-- Notification Banner (Slide down from top) -->
            <Border x:Name="NotificationBanner" 
                    VerticalAlignment="Top" 
                    HorizontalAlignment="Center" 
                    Margin="0,-60,0,0" 
                    Height="44" 
                    Background="{DynamicResource ModalBoxBgBrush}" 
                    BorderBrush="{DynamicResource GreenBrush}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="16,0,8,0" 
                    Panel.ZIndex="2000"
                    Width="440">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="Black" Opacity="0.12"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Path Grid.Column="0" Data="M 12 5 L 5 12 L 2 9" Stroke="{DynamicResource GreenBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="10" Height="10" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1" x:Name="TxtNotification" Text="All engine components have been successfully updated!" Style="{StaticResource BaseTextBlockStyle}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" x:Name="BtnCloseNotification" Width="24" Height="24" Background="Transparent" BorderThickness="0" Click="BtnCloseNotification_Click" VerticalAlignment="Center">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent">
                                                <Path x:Name="icon" Data="M 6 6 L 18 18 M 18 6 L 6 18" Stroke="{DynamicResource TextDimBrush}" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center" Width="8" Height="8" Stretch="Uniform"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="icon" Property="Stroke" Value="{DynamicResource TextBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Main Window Layout (Sidebar + Content Area) -->
            <Grid x:Name="MainLayout">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/> <!-- Symmetric sidebar width -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ================= LEFT SIDEBAR ================= -->
                <Border Grid.Column="0" 
                        Background="{DynamicResource SidebarBgBrush}" 
                        BorderBrush="{DynamicResource SidebarBorderBrush}" 
                        BorderThickness="0,0,1,0"
                        CornerRadius="12,0,0,12">
                    <Grid Margin="18,0,18,24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="48"/>   <!-- Align with Title Bar Row -->
                            <RowDefinition Height="Auto"/> <!-- Header (Logo + Brand) -->
                            <RowDefinition Height="*"/>    <!-- Spacer -->
                            <RowDefinition Height="Auto"/> <!-- Footer Controls -->
                        </Grid.RowDefinitions>

                        <!-- Sidebar Header (Logo + Brand) - Draggable -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center" MouseLeftButtonDown="Window_MouseLeftButtonDown" Margin="0,11,0,0">
                            <Border CornerRadius="10" Width="42" Height="42" ClipToBounds="True" Background="Transparent" Margin="0,0,12,0">
                                <!-- High-res PNG logo without text, perfectly sharp -->
                                <Image Source="pack://application:,,,/PatreonArchiverBridge.UI.Shared;component/Resources/logo.png" 
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Stretch="Uniform"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Patreon Archiver" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="15"/>
                                <TextBlock Text="Bridge Control" Style="{StaticResource BaseTextBlockStyle}" FontSize="11" Foreground="{DynamicResource TextDimBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Sidebar Footer (Theme Toggle + Settings Gear) -->
                        <StackPanel Grid.Row="3" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Theme Toggle Round Button -->
                            <Button Style="{StaticResource RoundIconButtonStyle}" Click="BtnThemeToggle_Click" Margin="0,0,12,0">
                                <Grid>
                                    <!-- Sun Icon (Visible in Dark Theme) -->
                                    <Path x:Name="PathSun" Data="M 12 7 A 5 5 0 1 0 12 17 A 5 5 0 1 0 12 7 M 12 1 V 3 M 12 21 V 23 M 4.22 4.22 L 5.64 5.64 M 18.36 18.36 L 19.78 19.78 M 1 12 H 3 M 21 12 H 23 M 4.22 19.78 L 5.64 18.36 M 18.36 5.64 L 19.78 4.22" 
                                          Stroke="{DynamicResource TextDimBrush}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Width="16" Height="16" Stretch="Uniform" Visibility="Collapsed"/>
                                    <!-- Moon Icon (Visible in Light Theme) -->
                                    <Path x:Name="PathMoon" Data="M 21 12.79 A 9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79 Z" 
                                          Fill="Transparent" Stroke="{DynamicResource TextDimBrush}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Width="16" Height="16" Stretch="Uniform" Visibility="Visible"/>
                                </Grid>
                            </Button>

                            <!-- Settings Gear Round Button -->
                            <Button Style="{StaticResource RoundIconButtonStyle}" Click="BtnSettingsOpen_Click" Margin="0,0,12,0">
                                <!-- Gear Icon -->
                                <Path Data="M 12 9 A 3 3 0 1 0 12 15 A 3 3 0 1 0 12 9 M 19.4 15 a 1.65 1.65 0 0 0 .33 1.82 l .06 .06 a 2 2 0 1 1 -2.83 2.83 l -.06 -.06 a 1.65 1.65 0 0 0 -1.82 -.33 a 1.65 1.65 0 0 0 -1 1.51 V 21 a 2 2 0 0 1 -4 0 v -.09 A 1.65 1.65 0 0 0 9 19.4 a 1.65 1.65 0 0 0 -1.82 .33 l -.06 .06 a 2 2 0 1 1 -2.83 -2.83 l .06 -.06 a 1.65 1.65 0 0 0 .33 -1.82 a 1.65 1.65 0 0 0 -1.51 -1 H 3 a 2 2 0 0 1 0 -4 h .09 A 1.65 1.65 0 0 0 4.6 9 a 1.65 1.65 0 0 0 -.33 -1.82 l -.06 -.06 a 2 2 0 1 1 2.83 -2.83 l .06 .06 a 1.65 1.65 0 0 0 1.82 .33 H 9 a 1.65 1.65 0 0 0 1 -1.51 V 3 a 2 2 0 0 1 4 0 v .09 a 1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82 -.33 l .06 -.06 a 2 2 0 1 1 2.83 2.83 l -.06 .06 a 1.65 1.65 0 0 0 -.33 1.82 V 9 a 1.65 1.65 0 0 0 1.51 1 H 21 a 2 2 0 0 1 0 4 h -.09 a 1.65 1.65 0 0 0 -1.51 1 Z" 
                                      Fill="Transparent" Stroke="{DynamicResource TextDimBrush}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>

                            <!-- Update Alert Notification (Pulsator Glow) -->
                            <Grid x:Name="GridUpdateAlert" Visibility="Collapsed" Width="36" Height="36" Margin="0,0,12,0">
                                <!-- Pulsator Rings (Layered behind the button) -->
                                <Canvas Width="36" Height="36" ClipToBounds="False" IsHitTestVisible="False">
                                    <!-- Ring 1: starts small, expands and fades out -->
                                    <Ellipse Width="36" Height="36" Fill="#EF4444" Opacity="0" RenderTransformOrigin="0.5,0.5">
                                        <Ellipse.RenderTransform>
                                            <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                                        </Ellipse.RenderTransform>
                                        <Ellipse.Triggers>
                                            <EventTrigger RoutedEvent="Ellipse.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                         From="0.9" To="1.4" Duration="0:0:2.8" RepeatBehavior="Forever">
                                                            <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                         From="0.9" To="1.4" Duration="0:0:2.8" RepeatBehavior="Forever">
                                                            <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="0.3" To="0.0" Duration="0:0:2.8" RepeatBehavior="Forever">
                                                            <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Ellipse.Triggers>
                                    </Ellipse>

                                    <!-- Ring 2: starts 1.4s later (exactly halfway through the 2.8s loop) -->
                                    <Ellipse Width="36" Height="36" Fill="#EF4444" Opacity="0" RenderTransformOrigin="0.5,0.5">
                                        <Ellipse.RenderTransform>
                                            <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                                        </Ellipse.RenderTransform>
                                        <Ellipse.Triggers>
                                            <EventTrigger RoutedEvent="Ellipse.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard BeginTime="0:0:1.4">
                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                         From="0.9" To="1.4" Duration="0:0:2.8" RepeatBehavior="Forever">
                                                            <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                         From="0.9" To="1.4" Duration="0:0:2.8" RepeatBehavior="Forever">
                                                            <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="0.3" To="0.0" Duration="0:0:2.8" RepeatBehavior="Forever">
                                                            <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Ellipse.Triggers>
                                    </Ellipse>
                                </Canvas>

                                <!-- Central Solid Red Button with clean white exclamation path and custom hover style -->
                                <Button x:Name="BtnUpdateAlert" Style="{StaticResource UpdateAlertButtonStyle}" Click="BtnUpdateAlert_Click" 
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path Data="M 12 8 V 12 M 12 16 H 12.01" 
                                          Stroke="White" StrokeThickness="2.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ================= RIGHT PANEL ================= -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="48"/>   <!-- Draggable Title Bar Controls -->
                        <RowDefinition Height="Auto"/> <!-- Status Header -->
                        <RowDefinition Height="*"/>    <!-- Cards List -->
                        <RowDefinition Height="Auto"/> <!-- Footer Version tag -->
                    </Grid.RowDefinitions>

                    <!-- Title Bar Area -->
                    <Grid Grid.Row="0" Background="Transparent">
                        <Border Background="Transparent" MouseLeftButtonDown="Window_MouseLeftButtonDown"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <!-- Minimize Button -->
                            <Button x:Name="BtnMinimize" Click="BtnMinimize_Click" Width="40" Height="32" Background="Transparent" BorderThickness="0" WindowChrome.IsHitTestVisibleInChrome="True">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="Transparent">
                                                        <Path x:Name="icon" Data="M 6 12 H 18" Stroke="{DynamicResource TextDimBrush}" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center" Width="10" Height="10" Stretch="Uniform"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="icon" Property="Stroke" Value="{DynamicResource TextBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            
                            <!-- Close Button -->
                            <Button x:Name="BtnClose" Click="BtnClose_Click" Width="40" Height="32" Background="Transparent" BorderThickness="0" WindowChrome.IsHitTestVisibleInChrome="True">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="Transparent">
                                                        <Path x:Name="icon" Data="M 6 6 L 18 18 M 18 6 L 6 18" Stroke="{DynamicResource TextDimBrush}" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center" Width="10" Height="10" Stretch="Uniform"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="icon" Property="Stroke" Value="#EF4444"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- 1. Header (Status Circle + Title) -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="40,8,40,24">
                        <!-- Status Circle -->
                        <Grid Width="48" Height="48" Margin="0,0,16,0">
                            <Border x:Name="BrdStatusCircle" CornerRadius="24" Background="{DynamicResource GreenBgBrush}">
                                <Path x:Name="PathStatusIcon" Data="M 20 6 L 9 17 L 4 12" 
                                      Stroke="{DynamicResource GreenBrush}" StrokeThickness="3" 
                                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <!-- Status Texts -->
                        <StackPanel VerticalAlignment="Center" Width="380">
                            <TextBlock x:Name="TxtStatusTitle" Style="{StaticResource BaseTextBlockStyle}" Text="Everything is working" FontWeight="Bold" FontSize="20"/>
                             <TextBlock x:Name="TxtStatusSub" Style="{StaticResource BaseTextBlockStyle}" Text="Feel free to close this window. The extension runs in the background when it's needed." FontSize="12.5" Foreground="{DynamicResource TextDimBrush}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 2. Cards List -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="40,0,40,16">
                        <StackPanel>
                            <!-- Card 1: Chrome Extension -->
                            <Border Style="{StaticResource StatusCardStyle}" Padding="20,16" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/> <!-- Icon -->
                                        <ColumnDefinition Width="*"/>    <!-- Details (Flexible width) -->
                                        <ColumnDefinition Width="Auto"/> <!-- Action Button -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Extension Aperture Icon -->
                                    <!-- Extension Puzzle Icon -->
                                    <Border Grid.Column="0" CornerRadius="10" Width="40" Height="40" Background="{DynamicResource IconBgBrush}" Margin="0,0,16,0">
                                        <Path Data="M 19 11 H 17 V 9 A 2 2 0 0 0 15 7 H 13 V 5 A 3 3 0 0 0 7 5 V 7 H 5 A 2 2 0 0 0 3 9 V 11 H 1 A 3 3 0 0 0 1 17 H 3 V 19 A 2 2 0 0 0 5 21 H 7 V 19 A 3 3 0 0 1 13 19 V 21 H 15 A 2 2 0 0 0 17 19 V 17 H 19 A 3 3 0 0 0 19 11 Z" 
                                              Stroke="{DynamicResource IconColorBrush}" StrokeThickness="2" 
                                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="Transparent"/>
                                    </Border>

                                    <!-- Details (Using Grid to constrain child size and trigger ellipsis, preventing button overlap) -->
                                    <Grid Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="Chrome Extension" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="13.5"/>
                                        <Grid Grid.Row="1" Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border x:Name="DotRegistry" Grid.Column="0" CornerRadius="3.5" Width="7" Height="7" Background="#10B981" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="TxtRegistry" Grid.Column="1" Style="{StaticResource BaseTextBlockStyle}" Text="Registered successfully" FontSize="11.5" Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                        </Grid>
                                    </Grid>

                                    <!-- Action -->
                                    <Button x:Name="BtnRegister" Grid.Column="2" Style="{StaticResource AccentButtonStyle}" Content="Repair" Click="BtnRegister_Click" Height="30" FontSize="11.5" Padding="12,0" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Card 2: Video Engine (yt-dlp) -->
                            <Border Style="{StaticResource StatusCardStyle}" Padding="20,16" Margin="0,0,0,12" ClipToBounds="True">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/> <!-- Icon -->
                                            <ColumnDefinition Width="*"/>    <!-- Details -->
                                            <ColumnDefinition Width="Auto"/> <!-- Action Button -->
                                        </Grid.ColumnDefinitions>

                                        <!-- Video Engine Play Icon -->
                                        <Border Grid.Column="0" CornerRadius="10" Width="40" Height="40" Background="{DynamicResource IconBgBrush}" Margin="0,0,16,0">
                                            <Path Data="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z M10 8l6 4-6 4V8z" 
                                                  Stroke="{DynamicResource IconColorBrush}" StrokeThickness="2" 
                                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="Transparent"/>
                                        </Border>

                                        <!-- Details -->
                                        <Grid Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="Video Engine" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="13.5"/>
                                            <Grid Grid.Row="1" Margin="0,4,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border x:Name="DotYtdlp" Grid.Column="0" CornerRadius="3.5" Width="7" Height="7" Background="#10B981" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock x:Name="TxtYtdlp" Grid.Column="1" Style="{StaticResource BaseTextBlockStyle}" Text="Checking..." FontSize="11.5" Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                            </Grid>
                                        </Grid>

                                        <!-- Action -->
                                        <Button x:Name="BtnYtdlpAction" Grid.Column="2" Style="{StaticResource AccentButtonStyle}" Content="Download" Click="BtnYtdlpAction_Click" Height="30" FontSize="11.5" Padding="12,0" VerticalAlignment="Center" Visibility="Collapsed"/>
                                    </Grid>

                                    <!-- Download progress bar for yt-dlp -->
                                    <ProgressBar x:Name="ProgressYtdlp" Grid.Row="1" Height="3" Margin="-20,12,-20,-16" 
                                                 BorderThickness="0" Background="{DynamicResource SidebarBorderBrush}" Foreground="{DynamicResource AccentBrush}" 
                                                 Visibility="Collapsed"/>
                                </Grid>
                            </Border>

                            <!-- Card 3: Video Merger (FFmpeg) -->
                            <Border Style="{StaticResource StatusCardStyle}" Padding="20,16" Margin="0,0,0,12" ClipToBounds="True">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/> <!-- Icon -->
                                            <ColumnDefinition Width="*"/>    <!-- Details -->
                                            <ColumnDefinition Width="Auto"/> <!-- Action Button -->
                                        </Grid.ColumnDefinitions>

                                        <!-- Video Merger Film Strip Icon -->
                                        <Border Grid.Column="0" CornerRadius="10" Width="40" Height="40" Background="{DynamicResource IconBgBrush}" Margin="0,0,16,0">
                                            <Path Data="M 4 2 H 20 A 2 2 0 0 1 22 4 V 20 A 2 2 0 0 1 20 22 H 4 A 2 2 0 0 1 2 20 V 4 A 2 2 0 0 1 4 2 Z M 8 2 V 22 M 16 2 V 22 M 2 7 H 8 M 2 12 H 8 M 2 17 H 8 M 16 7 H 22 M 16 12 H 22 M 16 17 H 22" 
                                                  Stroke="{DynamicResource IconColorBrush}" StrokeThickness="2" 
                                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="Transparent"/>
                                        </Border>

                                        <!-- Details -->
                                        <Grid Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="Video Merger (FFmpeg)" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="13.5"/>
                                            <Grid Grid.Row="1" Margin="0,4,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border x:Name="DotFfmpeg" Grid.Column="0" CornerRadius="3.5" Width="7" Height="7" Background="#10B981" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock x:Name="TxtFfmpeg" Grid.Column="1" Style="{StaticResource BaseTextBlockStyle}" Text="Checking..." FontSize="11.5" Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                            </Grid>
                                        </Grid>

                                        <!-- Action -->
                                        <Button x:Name="BtnFfmpegAction" Grid.Column="2" Style="{StaticResource AccentButtonStyle}" Content="Download" Click="BtnFfmpegAction_Click" Height="30" FontSize="11.5" Padding="12,0" VerticalAlignment="Center" Visibility="Collapsed"/>
                                    </Grid>

                                    <!-- Download progress bar for FFmpeg -->
                                    <ProgressBar x:Name="ProgressFfmpeg" Grid.Row="1" Height="3" Margin="-20,12,-20,-16" 
                                                 BorderThickness="0" Background="{DynamicResource SidebarBorderBrush}" Foreground="{DynamicResource AccentBrush}" 
                                                 Visibility="Collapsed"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- 3. Bottom Info Bar -->
                    <Grid Grid.Row="3" Margin="40,0,40,24">
                        <TextBlock x:Name="TxtVersion" Style="{StaticResource BaseTextBlockStyle}" Text="Bridge Version 1.0.0" FontSize="11.5" Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </Grid>

            <!-- ================= FLOATING SETTINGS OVERLAY MODAL ================= -->
            <Grid x:Name="SettingsOverlay" Background="{DynamicResource ModalOverlayBrush}" Visibility="Collapsed" Panel.ZIndex="100" Opacity="0" MouseLeftButtonDown="SettingsOverlay_MouseLeftButtonDown">
                <!-- Modal Box with Custom transform anchors for scale/translate transition animations -->
                <Border x:Name="SettingsModalBox" Style="{StaticResource CardStyle}" Background="{DynamicResource ModalBoxBgBrush}" Width="460" Height="480" VerticalAlignment="Center" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="ModalScale" ScaleX="0.96" ScaleY="0.96"/>
                            <TranslateTransform x:Name="ModalTranslate" Y="15"/>
                        </TransformGroup>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Title -->
                            <RowDefinition Height="*"/>    <!-- Scrollable content -->
                            <RowDefinition Height="Auto"/> <!-- Done Button -->
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Settings" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="20" Margin="0,0,0,16"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                            <StackPanel>
                                <!-- Row 1: Dark Mode -->
                                <Border BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,14" Margin="0,0,0,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Dark mode" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="13.5"/>
                                            <TextBlock Text="Switch to the dark color scheme." Style="{StaticResource BaseTextBlockStyle}" FontSize="11.5" Foreground="{DynamicResource TextDimBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <!-- Using Checkbox styled as toggle -->
                                        <CheckBox x:Name="ChkSettingsDark" Grid.Column="1" Style="{StaticResource SwitchToggleStyle}" Click="ChkSettingsDark_Click" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>



                                <!-- Row 4: Support Files -->
                                <Border BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,14" Margin="0,0,0,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Support files" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="13.5"/>
                                            <TextBlock Text="Open the log folder for troubleshooting." Style="{StaticResource BaseTextBlockStyle}" FontSize="11.5" Foreground="{DynamicResource TextDimBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Content="Open" Click="BtnOpenLogs_Click" Height="30" FontSize="11.5" Padding="12,0"/>
                                    </Grid>
                                </Border>

                                <!-- Row 5: Links & Support -->
                                <Border BorderBrush="Transparent" BorderThickness="0" Padding="0" Margin="0,6,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Links &amp; Support" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="13.5" Margin="0,0,0,12"/>
                                        <UniformGrid Columns="2" Rows="2">
                                            <Button x:Name="BtnTelegram" Style="{StaticResource SecondaryButtonStyle}" Click="BtnTelegram_Click" Margin="0,0,4,8" Height="32" Padding="8,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <!-- Message/Telegram Icon -->
                                                    <Path Data="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" 
                                                          Stroke="{DynamicResource TextBrush}" StrokeThickness="1.5" Fill="Transparent" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Telegram Support" FontSize="11" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="BtnCoffee" Style="{StaticResource SecondaryButtonStyle}" Click="BtnCoffee_Click" Margin="4,0,0,8" Height="32" Padding="8,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <!-- Coffee Cup Icon -->
                                                    <Path Data="M18 8h1a4 4 0 0 1 0 8h-1M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z M6 1v3 M10 1v3 M14 1v3" 
                                                          Stroke="{DynamicResource TextBrush}" StrokeThickness="1.5" Fill="Transparent" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Buy Me a Coffee" FontSize="11" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="BtnGitHub" Style="{StaticResource SecondaryButtonStyle}" Click="BtnGitHub_Click" Margin="0,0,4,0" Height="32" Padding="8,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <!-- GitHub Mark Icon -->
                                                    <Path Data="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" 
                                                          Stroke="{DynamicResource TextBrush}" StrokeThickness="1.5" Fill="Transparent" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="GitHub Repository" FontSize="11" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="BtnRate" Style="{StaticResource SecondaryButtonStyle}" Click="BtnRate_Click" Margin="4,0,0,0" Height="32" Padding="8,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <!-- Star Icon -->
                                                    <Path Data="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" 
                                                          Stroke="{DynamicResource TextBrush}" StrokeThickness="1.5" Fill="Transparent" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Rate Extension" FontSize="11" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Done Button -->
                        <Button Grid.Row="2" Style="{StaticResource AccentButtonStyle}" Content="Done" Click="BtnSettingsClose_Click" Margin="0,16,0,0"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ================= FLOATING UPDATE OVERLAY MODAL ================= -->
            <Grid x:Name="UpdateOverlay" Background="{DynamicResource ModalOverlayBrush}" Visibility="Collapsed" Panel.ZIndex="100" Opacity="0">
                <!-- Modal Box with Custom transform anchors for scale/translate transition animations -->
                <Border x:Name="UpdateModalBox" Style="{StaticResource CardStyle}" Background="{DynamicResource ModalBoxBgBrush}" Width="460" Height="360" VerticalAlignment="Center" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="UpdateModalScale" ScaleX="0.96" ScaleY="0.96"/>
                            <TranslateTransform x:Name="UpdateModalTranslate" Y="15"/>
                        </TransformGroup>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Title / Icon -->
                            <RowDefinition Height="*"/>    <!-- Release Notes / Scroll Area -->
                            <RowDefinition Height="Auto"/> <!-- Actions -->
                        </Grid.RowDefinitions>

                        <!-- Title Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="{DynamicResource IconBgBrush}" CornerRadius="10" Width="42" Height="42" Margin="0,0,16,0" VerticalAlignment="Center">
                                <!-- Sparkles/Update Icon -->
                                <Path Data="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" 
                                      Stroke="{DynamicResource AccentBrush}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="Transparent"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="New Update Available!" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="18"/>
                                <TextBlock x:Name="TxtUpdateVersions" Text="Version 1.0.0 → 1.1.0" Style="{StaticResource BaseTextBlockStyle}" FontSize="12" Foreground="{DynamicResource TextDimBrush}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Scrollable Release Notes -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                            <StackPanel>
                                <TextBlock Text="Release Notes" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="13.5" Margin="0,0,0,8"/>
                                <TextBlock x:Name="TxtReleaseNotes" Style="{StaticResource BaseTextBlockStyle}" FontSize="12.5" TextWrapping="Wrap" LineHeight="18" Foreground="{DynamicResource TextBrush}"
                                           Text="• Improved download stability and speed.&#x0a;• Fixed minimizing and closing window borders.&#x0a;• Added seamless background update notifications.&#x0a;• Cleaned UI alignment and styling."/>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Actions Grid -->
                        <Grid Grid.Row="2" Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Style="{StaticResource SecondaryButtonStyle}" Content="Maybe later" Click="BtnUpdateLater_Click" Height="34" Margin="0,0,6,0" FontSize="12" Padding="12,0"/>
                            <Button Grid.Column="1" Style="{StaticResource AccentButtonStyle}" Content="Update now" Click="BtnUpdateNow_Click" Height="34" Margin="6,0,0,0" FontSize="12" Padding="12,0"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ================= FLOATING WHATS NEW OVERLAY MODAL ================= -->
            <Grid x:Name="WhatsNewOverlay" Background="{DynamicResource ModalOverlayBrush}" Visibility="Collapsed" Panel.ZIndex="100" Opacity="0">
                <!-- Modal Box with Custom transform anchors for scale/translate transition animations -->
                <Border x:Name="WhatsNewModalBox" Style="{StaticResource CardStyle}" Background="{DynamicResource ModalBoxBgBrush}" Width="460" Height="360" VerticalAlignment="Center" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="WhatsNewModalScale" ScaleX="0.96" ScaleY="0.96"/>
                            <TranslateTransform x:Name="WhatsNewModalTranslate" Y="15"/>
                        </TransformGroup>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Title / Icon -->
                            <RowDefinition Height="*"/>    <!-- Features / Notes -->
                            <RowDefinition Height="Auto"/> <!-- Close Button -->
                        </Grid.RowDefinitions>

                        <!-- Title Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="{DynamicResource GreenBgBrush}" CornerRadius="10" Width="42" Height="42" Margin="0,0,16,0" VerticalAlignment="Center">
                                <!-- Confetti/Success Icon -->
                                <Path Data="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" 
                                      Stroke="{DynamicResource GreenBrush}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="Transparent"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Successfully Updated!" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="18"/>
                                <TextBlock x:Name="TxtWhatsNewVersion" Text="Welcome to v1.1.0" Style="{StaticResource BaseTextBlockStyle}" FontSize="12" Foreground="{DynamicResource TextDimBrush}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Scrollable Release Notes -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                            <StackPanel>
                                <TextBlock Text="What's New in this version" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="13.5" Margin="0,0,0,8"/>
                                <TextBlock x:Name="TxtWhatsNewContent" Style="{StaticResource BaseTextBlockStyle}" FontSize="12.5" TextWrapping="Wrap" LineHeight="18" Foreground="{DynamicResource TextBrush}"
                                           Text="• Improved download stability and speed.&#x0a;• Fixed minimizing and closing window borders.&#x0a;• Added seamless background update notifications.&#x0a;• Cleaned UI alignment and styling."/>
                                <TextBlock Margin="0,16,0,0" FontSize="11.5" Foreground="{DynamicResource TextDimBrush}" TextWrapping="Wrap">
                                    <Run Text="You can always read the full changelog on "/>
                                    <Hyperlink Click="Hyperlink_Click" NavigateUri="https://github.com/placeholder-repo" Foreground="{DynamicResource AccentBrush}">GitHub</Hyperlink>
                                    <Run Text="."/>
                                </TextBlock>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Close Button -->
                        <Button Grid.Row="2" Style="{StaticResource AccentButtonStyle}" Content="Awesome, thanks!" Click="BtnWhatsNewClose_Click" Height="34" Margin="0,16,0,0" FontSize="12" Padding="12,0"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>

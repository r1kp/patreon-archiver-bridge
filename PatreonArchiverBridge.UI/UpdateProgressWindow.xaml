<Window x:Class="PatreonArchiverBridge.UI.UpdateProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Updating Patreon Archiver"
        Height="280" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Closing="Window_Closing"
        >

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="0" GlassFrameThickness="-1"/>
    </WindowChrome.WindowChrome>

    <Border x:Name="RootBorder" Background="{DynamicResource BgBrush}" BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="1" CornerRadius="12">
        <Grid x:Name="RootGrid" MouseLeftButtonDown="Grid_MouseLeftButtonDown">
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>   <!-- Custom Header/Drag Area -->
                <RowDefinition Height="*"/>    <!-- Main Content -->
            </Grid.RowDefinitions>

            <!-- Custom Titlebar Drag Area -->
            <Grid Grid.Row="0">
                <TextBlock Text="Updating Patreon Archiver..." Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center" Margin="16,0,0,0" FontSize="11.5" Foreground="{DynamicResource TextDimBrush}"/>
                <!-- Close/Cancel Button -->
                <Button x:Name="BtnClose" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Background="Transparent" BorderThickness="0" Click="BtnClose_Click" Width="28" Height="28" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Data="M 6 6 L 14 14 M 14 6 L 6 14" Stroke="{DynamicResource TextDimBrush}" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="10" Height="10" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </Grid>

            <!-- Main Content Area -->
            <Grid Grid.Row="1" Margin="24,0,24,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Spinner and percentage -->
                    <RowDefinition Height="*"/>    <!-- Rotating status messages -->
                </Grid.RowDefinitions>

                <!-- Circle Spinner and Percentage -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,8,0,16">
                    <Grid Width="60" Height="60">
                        <!-- Background Circle Track -->
                        <Ellipse Stroke="{DynamicResource SidebarBorderBrush}" StrokeThickness="4"/>
                        <!-- Foreground Animated Spinner Arc -->
                        <Border Width="60" Height="60" CornerRadius="30" BorderThickness="4,0,0,0" BorderBrush="{DynamicResource AccentBrush}" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <RotateTransform x:Name="SpinnerRotation" Angle="0"/>
                            </Border.RenderTransform>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Border.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SpinnerRotation" Storyboard.TargetProperty="Angle"
                                                             From="0" To="360" Duration="0:0:1.2" RepeatBehavior="Forever"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                        </Border>
                        <!-- Center Percentage Text -->
                        <TextBlock x:Name="TxtPercent" Text="0%" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <!-- Rotating Status and Relaxed Messages -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="TxtDownloading" Text="Downloading updates..." Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock x:Name="TxtFunnyStatus" Text="Brewing fresh coffee..." Style="{StaticResource BaseTextBlockStyle}" FontSize="12" Foreground="{DynamicResource TextDimBrush}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>

            <!-- Custom Cancel Confirmation Overlay -->
            <Grid x:Name="CancelOverlay" Grid.RowSpan="2" Background="{DynamicResource ModalOverlayBrush}" Visibility="Collapsed" Panel.ZIndex="100" Opacity="0">
                <Border x:Name="CancelModalBox" Style="{StaticResource CardStyle}" Background="{DynamicResource ModalBoxBgBrush}" Width="320" Height="170" VerticalAlignment="Center" HorizontalAlignment="Center" CornerRadius="12" RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="CancelModalScale" ScaleX="0.96" ScaleY="0.96"/>
                            <TranslateTransform x:Name="CancelModalTranslate" Y="10"/>
                        </TransformGroup>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>    <!-- Text -->
                            <RowDefinition Height="Auto"/> <!-- Buttons -->
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" VerticalAlignment="Center">
                            <TextBlock Text="Cancel Update?" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="14.5" Margin="0,0,0,6"/>
                            <TextBlock Text="Are you sure you want to stop updating? The app will remain on the current version." Style="{StaticResource BaseTextBlockStyle}" FontSize="11.5" Foreground="{DynamicResource TextDimBrush}" TextWrapping="Wrap" LineHeight="16"/>
                        </StackPanel>
                        
                        <Grid Grid.Row="1" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Style="{StaticResource SecondaryButtonStyle}" Content="No, continue" Click="BtnCancelNo_Click" Height="30" Margin="0,0,4,0" FontSize="11" Padding="0"/>
                            <Button Grid.Column="1" Style="{StaticResource AccentButtonStyle}" Content="Yes, stop" Click="BtnCancelYes_Click" Background="#EF4444" BorderBrush="#EF4444" Foreground="White" Height="30" Margin="4,0,0,0" FontSize="11" Padding="0"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>

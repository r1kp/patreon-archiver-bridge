<Window x:Class="PatreonArchiverBridge.UI.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Loading"
        Width="180" Height="180"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        Topmost="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
 
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="0" GlassFrameThickness="-1"/>
    </WindowChrome.WindowChrome>
 

 
    <Border Background="{DynamicResource BgBrush}"
            BorderBrush="{DynamicResource SidebarBorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <!-- Background glow removed entirely for clean glassy design -->

            <!-- The Bridge Icon (Pure White outline, exact match to the design) -->
            <Canvas x:Name="BridgeCanvas" Width="100" Height="80" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Canvas.Resources>
                    <Style TargetType="Path">
                        <Setter Property="Stroke" Value="White"/>
                        <Setter Property="StrokeStartLineCap" Value="Round"/>
                        <Setter Property="StrokeEndLineCap" Value="Round"/>
                    </Style>
                </Canvas.Resources>

                <!-- Bottom Ground Line -->
                <Path x:Name="GroundPath" Data="M 15,68 L 85,68" StrokeThickness="1.5" Opacity="0.35" StrokeDashArray="70" StrokeDashOffset="70"/>

                <!-- Pillars under the deck -->
                <Path x:Name="LeftPillarPath" Data="M 30,52 L 30,64" StrokeThickness="3" StrokeDashArray="12" StrokeDashOffset="12"/>
                <Path x:Name="RightPillarPath" Data="M 70,52 L 70,64" StrokeThickness="3" StrokeDashArray="12" StrokeDashOffset="12"/>

                <!-- Main Towers (Pylons) -->
                <Path x:Name="LeftTowerPath" Data="M 30,22 L 30,52" StrokeThickness="3.5" StrokeDashArray="30" StrokeDashOffset="30"/>
                <Path x:Name="RightTowerPath" Data="M 70,22 L 70,52" StrokeThickness="3.5" StrokeDashArray="30" StrokeDashOffset="30"/>

                <!-- Outer diagonal cables -->
                <Path x:Name="LeftOuterCablePath" Data="M 30,22 L 17,52" StrokeThickness="2.2" StrokeDashArray="35" StrokeDashOffset="35"/>
                <Path x:Name="RightOuterCablePath" Data="M 70,22 L 83,52" StrokeThickness="2.2" StrokeDashArray="35" StrokeDashOffset="35"/>

                <!-- Center sagging Arch -->
                <Path x:Name="ArchPath" Data="M 30,22 C 40,36 60,36 70,22" StrokeThickness="2.2" StrokeDashArray="45" StrokeDashOffset="45"/>

                <!-- Main Road Deck -->
                <Path x:Name="DeckPath" Data="M 12,52 L 88,52" StrokeThickness="4" StrokeDashArray="76" StrokeDashOffset="76"/>

                <!-- Hangers (Vertical cables) -->
                <Path x:Name="Hanger1Path" Data="M 38,26.5 L 38,52" StrokeThickness="2" StrokeDashArray="26" StrokeDashOffset="26"/>
                <Path x:Name="Hanger2Path" Data="M 46,28.8 L 46,52" StrokeThickness="2" StrokeDashArray="24" StrokeDashOffset="24"/>
                <Path x:Name="Hanger3Path" Data="M 54,28.8 L 54,52" StrokeThickness="2" StrokeDashArray="24" StrokeDashOffset="24"/>
                <Path x:Name="Hanger4Path" Data="M 62,26.5 L 62,52" StrokeThickness="2" StrokeDashArray="26" StrokeDashOffset="26"/>
            </Canvas>
        </Grid>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <!-- Loop Duration: 1.2s build + 1.2s hold + 0.5s fade-out + 0.4s pause = 3.3s -->
                <Storyboard RepeatBehavior="Forever" Duration="0:0:3.3">
                    
                    <!-- === 1. Bottom Ground Line (0.0s -> 0.6s) === -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GroundPath" Storyboard.TargetProperty="StrokeDashOffset">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="70"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="0">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.4" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.9" Value="70">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <CubicEase EasingMode="EaseIn"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                    </DoubleAnimationUsingKeyFrames>

                    <!-- === 2. Road Deck (0.1s -> 0.8s) === -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="DeckPath" Storyboard.TargetProperty="StrokeDashOffset">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="76"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="76"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.8" Value="0">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.4" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.9" Value="76">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <CubicEase EasingMode="EaseIn"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                    </DoubleAnimationUsingKeyFrames>

                    <!-- === 3. Pillars (0.2s -> 0.7s) === -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LeftPillarPath" Storyboard.TargetProperty="StrokeDashOffset">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="12"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="12"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.7" Value="0">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.4" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.9" Value="12"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="RightPillarPath" Storyboard.TargetProperty="StrokeDashOffset">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="12"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="12"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.7" Value="0">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.4" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.9" Value="12"/>
                    </DoubleAnimationUsingKeyFrames>

                    <!-- === 4. Towers (0.25s -> 0.85s) === -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LeftTowerPath" Storyboard.TargetProperty="StrokeDashOffset">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="30"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="30"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.85" Value="0">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.4" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.9" Value="30"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="RightTowerPath" Storyboard.TargetProperty="StrokeDashOffset">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="30"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="30"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.85" Value="0">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.4" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.9" Value="30"/>
                    </DoubleAnimationUsingKeyFrames>

                    <!-- === 5. Outer Cables (0.35s -> 0.95s) === -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LeftOuterCablePath" Storyboard.TargetProperty="StrokeDashOffset">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="35"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.35" Value="35"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.95" Value="0">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.4" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.9" Value="35"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="RightOuterCablePath" Storyboard.TargetProperty="StrokeDashOffset">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="35"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.35" Value="35"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.95" Value="0">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.4" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.9" Value="35"/>
                    </DoubleAnimationUsingKeyFrames>

                    <!-- === 6. Center Arch Cable (0.4s -> 1.0s) === -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ArchPath" Storyboard.TargetProperty="StrokeDashOffset">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="45"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="45"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="0">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.4" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.9" Value="45"/>
                    </DoubleAnimationUsingKeyFrames>

                    <!-- === 7. Hangers (Staggered almost together: 0.5s -> 1.1s) === -->
                    <!-- Hanger 1 -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Hanger1Path" Storyboard.TargetProperty="StrokeDashOffset">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="26"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.5" Value="26"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.95" Value="0">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.4" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.9" Value="26"/>
                    </DoubleAnimationUsingKeyFrames>
                    <!-- Hanger 2 -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Hanger2Path" Storyboard.TargetProperty="StrokeDashOffset">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="24"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.55" Value="24"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="0">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.4" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.9" Value="24"/>
                    </DoubleAnimationUsingKeyFrames>
                    <!-- Hanger 3 -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Hanger3Path" Storyboard.TargetProperty="StrokeDashOffset">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="24"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="24"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:1.05" Value="0">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.4" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.9" Value="24"/>
                    </DoubleAnimationUsingKeyFrames>
                    <!-- Hanger 4 -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Hanger4Path" Storyboard.TargetProperty="StrokeDashOffset">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="26"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.65" Value="26"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:1.1" Value="0">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.4" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.9" Value="26"/>
                    </DoubleAnimationUsingKeyFrames>

                    <!-- === 8. Soft Canvas Fade-in/out to tie it all together === -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BridgeCanvas" Storyboard.TargetProperty="Opacity">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="1">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.4" Value="1"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.9" Value="0">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <CubicEase EasingMode="EaseIn"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <EasingDoubleKeyFrame KeyTime="0:0:3.3" Value="0"/>
                    </DoubleAnimationUsingKeyFrames>

                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>

<Window x:Class="PatreonArchiverBridge.Setup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shared="clr-namespace:PatreonArchiverBridge.UI.Shared;assembly=PatreonArchiverBridge.UI.Shared"
        mc:Ignorable="d"
        Title="Patreon Archiver Bridge - Setup" 
        Width="780" Height="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Loaded="Window_Loaded">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="0" GlassFrameThickness="-1"/>
    </WindowChrome.WindowChrome>

    <Border Background="{DynamicResource BgBrush}" BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="1" CornerRadius="12">
        <Grid>
            <!-- Main Content Container (this will be blurred) -->
            <Grid x:Name="MainContentGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDEBAR -->
                <Border Grid.Column="0" Background="{DynamicResource SidebarBgBrush}" BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="0,0,1,0" CornerRadius="12,0,0,12">
                    <Grid Background="Transparent" MouseLeftButtonDown="Window_MouseLeftButtonDown">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Brand Header -->
                            <RowDefinition Height="*"/>    <!-- Stepper List -->
                            <RowDefinition Height="Auto"/> <!-- Secure & Private Card -->
                        </Grid.RowDefinitions>

                        <!-- Brand Header -->
                        <StackPanel Grid.Row="0" Margin="24,32,24,20" Orientation="Horizontal" VerticalAlignment="Center" Background="Transparent">
                            <Border Width="40" Height="40" Background="{DynamicResource IconBgBrush}" BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="1" CornerRadius="10" Margin="0,0,12,0" SnapsToDevicePixels="True">
                                <Image x:Name="ImgLogo" Width="26" Height="26" RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Patreon Archiver" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="15"/>
                                <TextBlock Text="Bridge Setup" Style="{StaticResource BaseTextBlockStyle}" FontSize="12" Foreground="{DynamicResource TextDimBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Stepper List (Visual Step Items with dashed line connector) -->
                        <Grid Grid.Row="1" Margin="24,12,24,12">
                            <!-- Dashed line connector -->
                            <Rectangle Width="2" HorizontalAlignment="Left" Margin="17,12,0,12" Stroke="{DynamicResource SidebarBorderBrush}" StrokeDashArray="2,3" SnapsToDevicePixels="True"/>
                            
                            <StackPanel VerticalAlignment="Top" Margin="4,0,0,0">
                                <!-- Welcome Step -->
                                <Grid x:Name="StepItemWelcome" Margin="0,0,0,26">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Circle Border -->
                                    <Border x:Name="StepCircleWelcome" Grid.Column="0" Width="28" Height="28" CornerRadius="14" BorderThickness="2" BorderBrush="{DynamicResource AccentBrush}" Background="{DynamicResource CardBgBrush}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Ellipse x:Name="StepDotWelcome" Width="10" Height="10" Fill="{DynamicResource AccentBrush}" Visibility="Visible"/>
                                    </Border>
                                    <TextBlock x:Name="StepTextWelcome" Grid.Column="1" Text="Welcome" Style="{StaticResource BaseTextBlockStyle}" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                </Grid>

                                <!-- Options Step -->
                                <Grid x:Name="StepItemOptions" Margin="0,0,0,26">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="StepCircleOptions" Grid.Column="0" Width="28" Height="28" CornerRadius="14" BorderThickness="2" BorderBrush="{DynamicResource SidebarBorderBrush}" Background="{DynamicResource CardBgBrush}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Ellipse x:Name="StepDotOptions" Width="10" Height="10" Fill="{DynamicResource AccentBrush}" Visibility="Collapsed"/>
                                    </Border>
                                    <TextBlock x:Name="StepTextOptions" Grid.Column="1" Text="Install Options" Style="{StaticResource BaseTextBlockStyle}" FontSize="13.5" FontWeight="Medium" Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                </Grid>

                                <!-- Extras Step -->
                                <Grid x:Name="StepItemExtras" Margin="0,0,0,26">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="StepCircleExtras" Grid.Column="0" Width="28" Height="28" CornerRadius="14" BorderThickness="2" BorderBrush="{DynamicResource SidebarBorderBrush}" Background="{DynamicResource CardBgBrush}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Ellipse x:Name="StepDotExtras" Width="10" Height="10" Fill="{DynamicResource AccentBrush}" Visibility="Collapsed"/>
                                    </Border>
                                    <TextBlock x:Name="StepTextExtras" Grid.Column="1" Text="Extras" Style="{StaticResource BaseTextBlockStyle}" FontSize="13.5" FontWeight="Medium" Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                </Grid>

                                <!-- Installing Step -->
                                <Grid x:Name="StepItemInstalling" Margin="0,0,0,26">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="StepCircleInstalling" Grid.Column="0" Width="28" Height="28" CornerRadius="14" BorderThickness="2" BorderBrush="{DynamicResource SidebarBorderBrush}" Background="{DynamicResource CardBgBrush}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Ellipse x:Name="StepDotInstalling" Width="10" Height="10" Fill="{DynamicResource AccentBrush}" Visibility="Collapsed"/>
                                    </Border>
                                    <TextBlock x:Name="StepTextInstalling" Grid.Column="1" Text="Installing" Style="{StaticResource BaseTextBlockStyle}" FontSize="13.5" FontWeight="Medium" Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                </Grid>

                                <!-- Complete Step -->
                                <Grid x:Name="StepItemComplete" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="StepCircleComplete" Grid.Column="0" Width="28" Height="28" CornerRadius="14" BorderThickness="2" BorderBrush="{DynamicResource SidebarBorderBrush}" Background="{DynamicResource CardBgBrush}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Ellipse x:Name="StepDotComplete" Width="10" Height="10" Fill="{DynamicResource AccentBrush}" Visibility="Collapsed"/>
                                    </Border>
                                    <TextBlock x:Name="StepTextComplete" Grid.Column="1" Text="Complete" Style="{StaticResource BaseTextBlockStyle}" FontSize="13.5" FontWeight="Medium" Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <!-- Secure & Private Info Card -->
                        <Border Grid.Row="2" Margin="24,0,24,24" BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="1" CornerRadius="12" Background="{DynamicResource CardBgBrush}" Padding="16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Path Data="M 12 22 C 12 22 20 18 20 12 V 5 L 12 2 L 4 5 V 12 C 4 18 12 22 12 22 Z M 9 11 L 11 13 L 15 9" 
                                          Stroke="{DynamicResource AccentBrush}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0" Fill="Transparent"/>
                                    <TextBlock Text="Secure &amp; Private" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="12.5"/>
                                </StackPanel>
                                <TextBlock Text="Patreon Archiver is open source and privacy focused." Style="{StaticResource BaseTextBlockStyle}" FontSize="11" Foreground="{DynamicResource TextDimBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- RIGHT MAIN PANEL -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="48"/>   <!-- Custom Title Bar controls -->
                        <RowDefinition Height="*"/>    <!-- Page Wizard Panels -->
                        <RowDefinition Height="Auto"/> <!-- Bottom Buttons Footer -->
                    </Grid.RowDefinitions>

                    <!-- Custom Title Bar Controls -->
                    <Grid Grid.Row="0" Background="Transparent">
                        <!-- Invisible drag border overlay -->
                        <Border Background="Transparent" MouseLeftButtonDown="Window_MouseLeftButtonDown"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">

                        <!-- Minimize Button -->
                        <Button x:Name="BtnMinimize" Click="BtnMinimize_Click" Width="40" Height="32" Background="Transparent" BorderThickness="0" WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="Transparent">
                                                    <Path x:Name="icon" Data="M 6 12 H 18" Stroke="{DynamicResource TextDimBrush}" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center" Width="10" Height="10" Stretch="Uniform"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="icon" Property="Stroke" Value="{DynamicResource TextBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        
                        <!-- Close Button -->
                        <Button x:Name="BtnClose" Click="BtnClose_Click" Width="40" Height="32" Background="Transparent" BorderThickness="0" WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="Transparent">
                                                    <Path x:Name="icon" Data="M 6 6 L 18 18 M 18 6 L 6 18" Stroke="{DynamicResource TextDimBrush}" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center" Width="10" Height="10" Stretch="Uniform"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="icon" Property="Stroke" Value="#EF4444"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Page Wizard Panels -->
                <Grid Grid.Row="1" Margin="48,-16,16,20">
                    <!-- Page 0: Welcome / License EULA -->
                    <Grid x:Name="PanelWelcome" Visibility="Visible">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" shared:ScrollViewerBehavior.IsEnabled="True">
                            <StackPanel Margin="0,0,12,0">
                                <!-- Page Header inside scrollable area -->
                                <StackPanel Margin="0,32,0,16">
                                    <TextBlock Text="End User License Agreement" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="22" Margin="0,0,0,4"/>
                                    <TextBlock Text="Please review the EULA before proceeding with the installation." Style="{StaticResource BaseTextBlockStyle}" FontSize="13.5" Foreground="{DynamicResource TextDimBrush}"/>
                                </StackPanel>

                                <!-- Existing Installation Info Badge -->
                                <Border x:Name="BrdExistingInfo" Style="{StaticResource CardStyle}" Background="#E0F2FE" BorderBrush="#bae6fd" Padding="14" Margin="0,0,0,16" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M 12 2 C 6.48 2 2 6.48 2 12 C 2 17.52 6.48 22 12 22 C 17.52 22 22 17.52 22 12 C 22 6.48 17.52 2 12 2 Z M 13 17 H 11 V 11 H 13 V 17 Z M 13 9 H 11 V 7 H 13 V 9 Z" 
                                              Fill="#0284c7" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Top" Margin="0,1,12,0"/>
                                        <TextBlock x:Name="TxtExistingInfo" Text="" Style="{StaticResource BaseTextBlockStyle}" FontSize="12.5" Foreground="#0369a1" TextWrapping="Wrap" FontWeight="Medium" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- EULA text Box (Card style matching step 2) -->
                                <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,16">
                                    <TextBlock x:Name="TxtEula" Text="" Style="{StaticResource BaseTextBlockStyle}" FontSize="11" FontFamily="Consolas" Foreground="{DynamicResource TextDimBrush}" TextWrapping="Wrap" LineHeight="16"/>
                                </Border>

                                <CheckBox x:Name="ChkAccept" Style="{StaticResource CheckboxStyle}" Content="I accept the agreement terms and conditions" Click="ChkAccept_Click" Margin="0,0,0,16"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- Page 1: Options -->
                    <Grid x:Name="PanelOptions" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" shared:ScrollViewerBehavior.IsEnabled="True">
                            <StackPanel Margin="0,0,12,0">
                                <!-- Page Header inside scrollable area -->
                                <StackPanel Margin="0,32,0,16">
                                    <TextBlock Text="Installation Options" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="22" Margin="0,0,0,4"/>
                                    <TextBlock Text="Choose where and how to install the bridge." Style="{StaticResource BaseTextBlockStyle}" FontSize="13.5" Foreground="{DynamicResource TextDimBrush}"/>
                                </StackPanel>

                                <!-- Card 1: Installation scope -->
                                <Border Style="{StaticResource CardStyle}" Padding="18" Margin="0,0,0,16">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                            <Path Data="M 16 21 V 19 A 4 4 0 0 0 12 15 H 6 A 4 4 0 0 0 2 19 V 21 M 9 3 A 4 4 0 1 0 9 11 A 4 4 0 1 0 9 3 Z M 22 21 V 19 A 4 4 0 0 0 19 15.13 M 16 3.13 A 4 4 0 1 1 16 10.88" 
                                                  Stroke="{DynamicResource TextDimBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Width="18" Height="18" Stretch="Uniform" Margin="0,0,10,0"/>
                                            <TextBlock Text="Installation Scope" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="14.5"/>
                                        </StackPanel>
                                        
                                        <RadioButton x:Name="RadioScopeMe" GroupName="Scope" Style="{StaticResource RadioButtonStyle}" IsChecked="True" Checked="RadioScope_Checked" Margin="28,0,0,10">
                                            <StackPanel Margin="6,0,0,0">
                                                <TextBlock Text="Just for me (no admin required)" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="13.5"/>
                                                <TextBlock Text="Installs for your user account only." Style="{StaticResource BaseTextBlockStyle}" FontSize="11.5" Foreground="{DynamicResource TextDimBrush}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </RadioButton>
                                        <RadioButton x:Name="RadioScopeAll" GroupName="Scope" Style="{StaticResource RadioButtonStyle}" Checked="RadioScope_Checked" Margin="28,0,0,0">
                                            <StackPanel Margin="6,0,0,0">
                                                <TextBlock Text="All users (requires elevation)" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="13.5"/>
                                                <TextBlock Text="Installs for all users on this computer." Style="{StaticResource BaseTextBlockStyle}" FontSize="11.5" Foreground="{DynamicResource TextDimBrush}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </RadioButton>
                                    </StackPanel>
                                </Border>

                                <!-- Card 2: Destination Folder -->
                                <Border Style="{StaticResource CardStyle}" Padding="18">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                            <Path Data="M 20 20 A 2 2 0 0 0 22 18 V 8 A 2 2 0 0 0 20 6 H 12.1 A 2 2 0 0 1 10.4 5.1 L 9.6 3.9 A 2 2 0 0 0 7.9 3 H 4 A 2 2 0 0 0 2 5 V 18 A 2 2 0 0 0 4 20 Z" 
                                                  Stroke="{DynamicResource TextDimBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Width="18" Height="18" Stretch="Uniform" Margin="0,0,10,0"/>
                                            <TextBlock Text="Destination Folder" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="14.5"/>
                                        </StackPanel>

                                        <!-- Browse Input Group -->
                                        <Grid Margin="28,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="TxtDestPath" Style="{StaticResource TextBoxStyle}" Grid.Column="0" IsReadOnly="True" VerticalContentAlignment="Center" Height="36"/>
                                            <Button x:Name="BtnBrowse" Style="{StaticResource SecondaryButtonStyle}" Grid.Column="1" Content="Browse..." Margin="12,0,0,0" Width="90" Height="36" Click="BtnBrowse_Click"/>
                                        </Grid>

                                        <!-- Shortcuts checkbox column (Vertical alignment to prevent cutting off) -->
                                        <StackPanel Orientation="Vertical" Margin="28,0,0,0">
                                            <CheckBox x:Name="ChkShortcutDesktop" Style="{StaticResource CheckboxStyle}" Content="Create desktop shortcut" IsChecked="True" Margin="0,0,0,10"/>
                                            <CheckBox x:Name="ChkShortcutStart" Style="{StaticResource CheckboxStyle}" Content="Create Start Menu entry" IsChecked="True"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- Page 2: Extras -->
                    <Grid x:Name="PanelExtras" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" shared:ScrollViewerBehavior.IsEnabled="True">
                            <StackPanel Margin="0,0,12,0">
                                <!-- Page Header inside scrollable area -->
                                <StackPanel Margin="0,32,0,16">
                                    <TextBlock Text="Extra Components" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="22" Margin="0,0,0,4"/>
                                    <TextBlock Text="Select optional components to download and include." Style="{StaticResource BaseTextBlockStyle}" FontSize="13.5" Foreground="{DynamicResource TextDimBrush}"/>
                                </StackPanel>

                                <!-- Card 1: yt-dlp -->
                                <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,12" x:Name="BrdYtdlp">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="ChkYtdlp" Grid.Column="0" Style="{StaticResource CheckboxStyle}" IsChecked="True" VerticalAlignment="Center" Margin="0,0,16,0" Click="ChkYtdlp_Click"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock x:Name="TxtYtdlpTitle" Text="yt-dlp video engine (Required for videos)" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="14"/>
                                            <TextBlock Text="Open-source engine used to retrieve embedded videos (YouTube/Vimeo) locked inside posts." Style="{StaticResource BaseTextBlockStyle}" FontSize="11.5" Foreground="{DynamicResource TextDimBrush}" Margin="0,3,0,0" TextWrapping="Wrap"/>
                                            <TextBlock x:Name="TxtWarnYtdlp" Text="⚠ Recommended for the extension to work" Style="{StaticResource BaseTextBlockStyle}" FontSize="11" Foreground="#EF4444" FontWeight="Medium" Margin="0,6,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Card 2: ffmpeg -->
                                <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,12" x:Name="BrdFfmpeg">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="ChkFfmpeg" Grid.Column="0" Style="{StaticResource CheckboxStyle}" IsChecked="True" VerticalAlignment="Center" Margin="0,0,16,0" Click="ChkFfmpeg_Click"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock x:Name="TxtFfmpegTitle" Text="ffmpeg and ffprobe (Required for merging)" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="14"/>
                                            <TextBlock Text="Required for merging separate video and audio streams, as well as post-processing tasks." Style="{StaticResource BaseTextBlockStyle}" FontSize="11.5" Foreground="{DynamicResource TextDimBrush}" Margin="0,3,0,0" TextWrapping="Wrap"/>
                                            <TextBlock x:Name="TxtWarnFfmpeg" Text="⚠ Recommended for the extension to work" Style="{StaticResource BaseTextBlockStyle}" FontSize="11" Foreground="#EF4444" FontWeight="Medium" Margin="0,6,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Card 3: yt-dlp-ejs -->
                                <Border Style="{StaticResource CardStyle}" Padding="16" x:Name="BrdYtdlpejs">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="ChkYtdlpejs" Grid.Column="0" Style="{StaticResource CheckboxStyle}" IsChecked="True" VerticalAlignment="Center" Margin="0,0,16,0" Click="ChkYtdlpejs_Click"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock x:Name="TxtYtdlpejsTitle" Text="yt-dlp-ejs (Required for YouTube support)" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="14"/>
                                            <TextBlock Text="Python wheel package providing YouTube decipher decryption solvers." Style="{StaticResource BaseTextBlockStyle}" FontSize="11.5" Foreground="{DynamicResource TextDimBrush}" Margin="0,3,0,0" TextWrapping="Wrap"/>
                                            <TextBlock x:Name="TxtWarnYtdlpejs" Text="⚠ Recommended for the extension to work" Style="{StaticResource BaseTextBlockStyle}" FontSize="11" Foreground="#EF4444" FontWeight="Medium" Margin="0,6,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- Page 3: Installing / Progress -->
                    <Grid x:Name="PanelProgress" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,32,0,24">
                            <TextBlock Text="Installing Files" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="22" Margin="0,0,0,4"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <!-- Status row directly above the bar -->
                            <Grid Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <TextBlock x:Name="TxtStatusLog" Text="Initializing directories" Style="{StaticResource BaseTextBlockStyle}" FontSize="12.5" Foreground="{DynamicResource TextDimBrush}" FontWeight="Medium"/>
                                    <!-- Gemini-style jumping dots -->
                                    <StackPanel x:Name="PanelJumpingDots" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="4,0,0,4">
                                        <StackPanel.Resources>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Width" Value="3"/>
                                                <Setter Property="Height" Value="3"/>
                                                <Setter Property="Fill" Value="{DynamicResource TextDimBrush}"/>
                                                <Setter Property="Margin" Value="1.5,0"/>
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <TranslateTransform Y="0"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </StackPanel.Resources>
                                        <Ellipse x:Name="Dot1">
                                            <Ellipse.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)">
                                                                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0"/>
                                                                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="-4">
                                                                    <EasingDoubleKeyFrame.EasingFunction>
                                                                        <QuadraticEase EasingMode="EaseOut"/>
                                                                    </EasingDoubleKeyFrame.EasingFunction>
                                                                </EasingDoubleKeyFrame>
                                                                <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="0">
                                                                    <EasingDoubleKeyFrame.EasingFunction>
                                                                        <QuadraticEase EasingMode="EaseIn"/>
                                                                    </EasingDoubleKeyFrame.EasingFunction>
                                                                </EasingDoubleKeyFrame>
                                                                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="0"/>
                                                            </DoubleAnimationUsingKeyFrames>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Ellipse.Triggers>
                                        </Ellipse>
                                        <Ellipse x:Name="Dot2">
                                            <Ellipse.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)">
                                                                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="0"/>
                                                                <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="-4">
                                                                    <EasingDoubleKeyFrame.EasingFunction>
                                                                        <QuadraticEase EasingMode="EaseOut"/>
                                                                    </EasingDoubleKeyFrame.EasingFunction>
                                                                </EasingDoubleKeyFrame>
                                                                <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="0">
                                                                    <EasingDoubleKeyFrame.EasingFunction>
                                                                        <QuadraticEase EasingMode="EaseIn"/>
                                                                    </EasingDoubleKeyFrame.EasingFunction>
                                                                </EasingDoubleKeyFrame>
                                                                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="0"/>
                                                            </DoubleAnimationUsingKeyFrames>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Ellipse.Triggers>
                                        </Ellipse>
                                        <Ellipse x:Name="Dot3">
                                            <Ellipse.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)">
                                                                <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="0"/>
                                                                <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="-4">
                                                                    <EasingDoubleKeyFrame.EasingFunction>
                                                                        <QuadraticEase EasingMode="EaseOut"/>
                                                                    </EasingDoubleKeyFrame.EasingFunction>
                                                                </EasingDoubleKeyFrame>
                                                                <EasingDoubleKeyFrame KeyTime="0:0:0.8" Value="0">
                                                                    <EasingDoubleKeyFrame.EasingFunction>
                                                                        <QuadraticEase EasingMode="EaseIn"/>
                                                                    </EasingDoubleKeyFrame.EasingFunction>
                                                                </EasingDoubleKeyFrame>
                                                                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="0"/>
                                                            </DoubleAnimationUsingKeyFrames>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Ellipse.Triggers>
                                        </Ellipse>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock x:Name="TxtProgressPercent" Text="0%" Style="{StaticResource BaseTextBlockStyle}" FontSize="12.5" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Right"/>
                            </Grid>

                            <!-- Custom Progress bar track -->
                            <Border BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="1" CornerRadius="3" Background="{DynamicResource SidebarBgBrush}" Height="8" SnapsToDevicePixels="True" Margin="0,0,0,16">
                                <Grid>
                                    <ProgressBar x:Name="ProgFill" Minimum="0" Maximum="100" Value="0" BorderThickness="0" Background="Transparent" Foreground="{DynamicResource AccentBrush}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Page 4: Success / Complete -->
                    <Grid x:Name="PanelComplete" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <!-- Large green checkmark icon -->
                            <Border Width="64" Height="64" CornerRadius="32" Background="{DynamicResource GreenBgBrush}" HorizontalAlignment="Center" Margin="0,0,0,18">
                                <Path Data="M 46 14 L 21 39 L 10 28" Stroke="{DynamicResource GreenBrush}" StrokeThickness="5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Width="28" Height="28" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="Transparent"/>
                            </Border>

                            <TextBlock Text="Setup Complete" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock x:Name="TxtCompleteMessage" Text="The Patreon Archiver Bridge has been installed successfully." Style="{StaticResource BaseTextBlockStyle}" FontSize="13.5" Foreground="{DynamicResource TextDimBrush}" HorizontalAlignment="Center" Margin="0,0,0,24"/>

                            <TextBlock Text="Please restart Google Chrome completely to allow Chrome to load the new bridge." 
                                       Style="{StaticResource BaseTextBlockStyle}" FontSize="12.5" Foreground="{DynamicResource TextDimBrush}" TextAlignment="Center" TextWrapping="Wrap" LineHeight="18" MaxWidth="420" Margin="0,0,0,24"/>

                            <CheckBox x:Name="ChkLaunchApp" Style="{StaticResource CheckboxStyle}" Content="Launch Bridge Control Center now" IsChecked="True" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- Bottom Buttons Footer -->
                <Border Grid.Row="2" BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="0,1,0,0" Padding="48,20,48,32">
                    <Grid>
                        <Button x:Name="BtnCancel" Style="{StaticResource SecondaryButtonStyle}" Content="Cancel" HorizontalAlignment="Left" Width="90" Click="BtnCancel_Click"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="BtnBack" Style="{StaticResource SecondaryButtonStyle}" Content="Back" Width="90" Visibility="Collapsed" Click="BtnBack_Click" Margin="0,0,12,0"/>
                            <Button x:Name="BtnNext" Style="{StaticResource AccentButtonStyle}" Content="Next" Width="90" Click="BtnNext_Click" IsEnabled="False"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Modern Cancel Confirmation Overlay (Hidden by default) -->
        <Grid x:Name="GridCancelOverlay" Grid.ColumnSpan="2" Background="{DynamicResource ModalOverlayBrush}" Visibility="Collapsed" Panel.ZIndex="1000">
                <Border Style="{StaticResource CardStyle}" Width="360" Height="180" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="24" BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="1" CornerRadius="16" Background="{DynamicResource CardBgBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock Text="Cancel Setup" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="18" Margin="0,0,0,8"/>
                            <TextBlock Text="Are you sure you want to cancel the installation?" Style="{StaticResource BaseTextBlockStyle}" FontSize="13" Foreground="{DynamicResource TextDimBrush}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource SecondaryButtonStyle}" Content="No" Width="90" Height="32" Padding="0" Click="BtnCancelNo_Click" Margin="0,0,12,0"/>
                            <Button Style="{StaticResource AccentButtonStyle}" Content="Yes" Width="90" Height="32" Padding="0" Click="BtnCancelYes_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
